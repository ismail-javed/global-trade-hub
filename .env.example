# Production site URL (no trailing slash). Used for canonical, OG URL, sitemap, and robots.txt.
VITE_SITE_URL=https://jnssioverseas.com

# Optional: override Formspree form URL (defaults are set in src/config/forms.js).
# VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# Admin auth (client-side). Use strong values.
# Option A (single password for all users)
# VITE_ADMIN_USERS=admin,owner
# VITE_ADMIN_PASSWORD=change-me
#
# Option B (different password per user)
# Format: user1:pass1,user2:pass2
VITE_ADMIN_CREDENTIALS=admin:change-me,owner:owner-123,editor:editor-123
